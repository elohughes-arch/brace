{
  "expo": {
    "name": "Brace",
    "slug": "brace",
    "scheme": "brace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0E12",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.braceshooting.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Brace reads your shooting footage from your photo library to turn it into your performance metrics.",
        "NSPhotoLibraryAddUsageDescription": "Brace saves processed clips back to your library when you choose to.",
        "NSCameraUsageDescription": "Brace can record a session directly through the camera."
      }
    },
    "android": {
      "package": "com.braceshooting.app",
      "permissions": [
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0B0E12",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Brace accesses your photos to import shooting footage to analyse."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Brace accesses your photos and videos to import shooting footage.",
          "savePhotosPermission": "Brace saves processed clips to your library when you choose to.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "8561f210-017b-4ea7-b7f5-dff8f55e05a8"
      }
    },
    "owner": "braceshooting",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8561f210-017b-4ea7-b7f5-dff8f55e05a8"
    }
  }
}
